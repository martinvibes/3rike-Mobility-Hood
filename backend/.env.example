# Server
PORT=8080
# Comma-separated allowed CORS origins (frontend dev server)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Auth — random 32+ byte secret
JWT_SECRET=replace-me
# 32-byte AES key as 64 hex chars (openssl rand -hex 32)
ENCRYPTION_KEY=replace-me

# Database (local dev uses SQLite; Railway will use Postgres)
DATABASE_URL="file:./dev.db"

# Robinhood Chain testnet
ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com
CHAIN_ID=46630
# Robinhood testnet USDC (symbol USDC, 6 decimals, openly mintable)
USDC_ADDRESS=0x5B6C7cAF7F99f99154fD8375ec935Fcf03F326f5
# Set after deploying ThreeRikeVault
VAULT_ADDRESS=
# Platform relayer/treasury — pays gas, mints settlement USDC (testnet only)
RELAYER_PRIVATE_KEY=replace-me
