# ─────────────────────────────────────────────────────────────────────────────
# 3rike backend env. Copy to .env for local dev; set the SAME keys in Railway.
# NEVER commit real secrets. Generate strong values for JWT_SECRET/ENCRYPTION_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8080
# Comma-separated allowed CORS origins. PROD: your Vercel URL, e.g.
# https://3rike.vercel.app   (add custom domains too, comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Auth
# JWT signing secret — random 32+ bytes (openssl rand -hex 32)
JWT_SECRET=replace-me
# AES-256 key for encrypting embedded wallet keys — 64 hex chars (openssl rand -hex 32)
ENCRYPTION_KEY=replace-me

# Database
# LOCAL: a Postgres URL (e.g. Neon/Supabase free, or local docker postgres).
# RAILWAY: provided automatically by the Postgres plugin — reference ${{Postgres.DATABASE_URL}}.
DATABASE_URL=postgresql://user:pass@host:5432/3rike?schema=public

# Robinhood Chain testnet (app chain)
ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com
CHAIN_ID=46630
USDC_ADDRESS=0x5B6C7cAF7F99f99154fD8375ec935Fcf03F326f5
VAULT_ADDRESS=0x34979dF7570697feB152468C3A17a51d0B9a34ED
# Investment contracts (current deploy — see contracts/deployments.md)
TRICYCLE_NFT_ADDRESS=0x64b84997414F7Bb301B5e6A2E228066e27C7EDd0
INVESTMENT_ADDRESS=0xBBE7ECa80d91e26E24A9f498B15239a5D975542B
# Platform relayer/owner — pays gas, mints settlement USDC, distributes yield.
# KEEP THIS WALLET FUNDED WITH TESTNET ETH (it's the gas tank for the whole app).
RELAYER_PRIVATE_KEY=replace-me

# ── Real-money rails (optional; needed only for bank deposit/withdraw) ──────────
# Arbitrum One mainnet treasury (holds real USDC backing the testnet ledger)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_USDC=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
TREASURY_ADDRESS=
TREASURY_PRIVATE_KEY=
# Paycrest (stablecoin <-> NGN). ROTATE the secret before production.
PAYCREST_BASE=https://api.paycrest.io/v1
PAYCREST_API_KEY=
PAYCREST_API_SECRET=
