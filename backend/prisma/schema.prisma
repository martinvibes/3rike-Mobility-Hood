// Prisma schema for the 3rike backend.
// Local dev uses SQLite for zero-setup; switch `provider` to "postgresql" for
// Railway (and point DATABASE_URL at the Postgres instance).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  role          String   @default("driver") // driver | investor
  // Editable profile fields.
  fullName      String?
  phone         String?
  country       String?
  address       String?
  pinHash       String?  // hashed 4-digit payment PIN
  // KYC / verification (gates loan eligibility). Server-side = follows the
  // account everywhere (no localStorage). none | verified.
  kycStatus     String   @default("none")
  kycFullName   String?
  kycIdNumber   String?  // national ID / BVN (demo: stored as-is)
  kycVerifiedAt DateTime?
  // The tricycle this rider is paying off (their "future 3rike"). Same asset
  // investors fractionally fund; the rider's weekly payments yield to them.
  tricycleId    Int?
  // Embedded EVM wallet auto-created on signup.
  walletAddress String   @unique
  encryptedKey  String   // AES-256-GCM encrypted private key
  createdAt     DateTime @default(now())

  deposits      Deposit[]
  paymentOrders PaymentOrder[]
  investments   Investment[]
  loans         Loan[]
  riderPayments RiderPayment[]
}

// Records on/off-chain money movements for history + auditing.
model Deposit {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  kind      String   // crypto | bank
  amountUsdc String  // decimal string (6dp)
  txHash    String?
  status    String   @default("confirmed") // pending | confirmed | failed
  createdAt DateTime @default(now())
}

// Paycrest treasury-bridge orders (real ₦ <-> real USDC on Arbitrum One).
model PaymentOrder {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  direction  String   // offramp (bank withdrawal) | onramp (bank deposit)
  paycrestId String   @unique
  amountUsdc String   // USDC moved through the treasury
  amountNgn  String?  // fiat leg
  status     String   @default("pending") // pending | settled | refunded | expired | failed
  txHash     String?  // treasury -> Paycrest receiveAddress (offramp funding)
  reference  String?
  createdAt  DateTime @default(now())
}

// History of fractional-investment actions. Ownership + yield live on-chain
// (source of truth); this is a fast, queryable log for receipts and activity
// feeds without scanning event logs.
model Investment {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  tricycleId  Int      // on-chain TricycleNFT tokenId
  vehicleId   String   // human fleet id (e.g. RDB-001) at time of action
  action      String   // invest | claim
  shares      String?  // shares bought (invest only)
  amountUsdc  String   // cost (invest) or yield claimed (claim), decimal 6dp
  txHash      String
  createdAt   DateTime @default(now())
}

// Micro-loans to riders. Gated by KYC + credit score. Principal is disbursed
// as USDC to the rider's wallet; they repay (principal + flat interest) over a
// term, which feeds their credit score.
model Loan {
  id              Int             @id @default(autoincrement())
  user            User            @relation(fields: [userId], references: [id])
  userId          Int
  principalUsdc   String          // amount borrowed (6dp decimal string)
  totalDueUsdc    String          // principal + interest
  outstandingUsdc String          // remaining to repay
  weeklyRepayment String          // suggested weekly amount
  termWeeks       Int
  interestPct     Int             // flat interest applied (e.g. 10)
  status          String          @default("active") // active | repaid
  disburseTxHash  String?
  createdAt       DateTime        @default(now())
  repaidAt        DateTime?
  repayments      LoanRepayment[]
}

model LoanRepayment {
  id         Int      @id @default(autoincrement())
  loan       Loan     @relation(fields: [loanId], references: [id])
  loanId     Int
  amountUsdc String
  txHash     String?
  createdAt  DateTime @default(now())
}

// A rider's weekly payment toward owning their tricycle. Part of each payment
// (the yield slice) is distributed on-chain to that tricycle's investors;
// the rest counts toward ownership. Also feeds the rider's credit score.
model RiderPayment {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  tricycleId  Int
  amountUsdc  String   // total the rider paid
  yieldUsdc   String   // portion distributed to investors
  txHash      String?  // wallet debit tx
  yieldTxHash String?  // distributeYield tx (null if pool had no investors)
  createdAt   DateTime @default(now())
}
